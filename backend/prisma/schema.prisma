generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite has no native enum type in Prisma, so status/priority are plain
// strings here. The allowed values are enforced at the app layer instead —
// see src/tasks/task.enums.ts and the class-validator @IsEnum() checks on
// the DTOs.
model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("pending")
  priority    String   @default("medium")
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tasks")
}
